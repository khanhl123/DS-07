# Copy to .env and fill in. The local backend (uvicorn) reads this via python-dotenv.
# In production, set these in the Render dashboard (Environment tab) for the
# ds07-weather-api service. They are declared with `sync: false` in render.yaml
# so they stay out of git.

# Neon Postgres connection string (read-only role is fine).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require

# Comma-separated list of origins the API will accept CORS requests from.
# In production this is the deployed Vercel URL (no trailing slash).
CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-main.vercel.app
